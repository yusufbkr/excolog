{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "env": ["VERCEL"],
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", ".vercel/output/**"]
    },
    "lint": {
      "env": ["NODE_ENV"],
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "env": ["NODE_ENV"],
      "dependsOn": ["^lint:fix"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "dependsOn": ["^db:generate"]
    },
    "hook:generate": {
      "dependsOn": ["^hook:generate"]
    }
  }
}
